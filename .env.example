# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# JWT
JWT_SECRET=change_me_to_a_random_string_min_64_chars_xxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_a_different_random_string_min_64_chars_yyyyyyyy
JWT_REFRESH_EXPIRES_IN=30d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=wauser
DB_PASSWORD=wapassword
DB_NAME=wa_automation
DB_SYNC=true
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenWA
OPENWA_BASE_URL=https://openwa.fts-tech.co.id
OPENWA_MASTER_KEY=api_key_from_openwa

# Encryption (must be exactly 32 chars for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
