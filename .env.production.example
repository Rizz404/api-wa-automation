# ── Production environment template ──
# Copy to `.env` on the server and fill in real values. NEVER commit the real .env.

NODE_ENV=production
PORT=3000
APP_URL=https://api.wa-automation.fts-tech.co.id

# JWT — generate with: openssl rand -hex 48
JWT_SECRET=__CHANGE_ME_64+_chars__
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=__CHANGE_ME_DIFFERENT_64+_chars__
JWT_REFRESH_EXPIRES_IN=30d

# Database (PostgreSQL 16)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=wauser
DB_PASSWORD=__STRONG_PASSWORD__
DB_NAME=wa_automation
# First deploy only: set true ONCE to create the schema on an empty DB, then set back to false.
DB_SYNC=false
DB_LOGGING=false

# Redis 7
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenWA
OPENWA_BASE_URL=https://openwa.fts-tech.co.id
OPENWA_MASTER_KEY=__OPENWA_KEY__

# Encryption — MUST be exactly 32 chars. Generate: openssl rand -hex 16
ENCRYPTION_KEY=__32_CHAR_KEY__

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
